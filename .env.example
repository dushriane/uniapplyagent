# ─────────────────────────────────────────────────────────────
# UniApply Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# Run `uniapply setup` to auto-populate the database IDs.
# ─────────────────────────────────────────────────────────────

# ── Notion ────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# and share your workspace pages with it.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# ── OpenAI ────────────────────────────────────────────────────
# Powers essay personalisation, comparison summaries, and interest
# pattern insights.  Omit to run in "rule-based only" mode.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Gmail (optional) ──────────────────────────────────────────
# Used to parse forwarded emails and send digest summaries.
GMAIL_USER=you@gmail.com
GMAIL_ALIAS=uniapply@yourdomain.com

# ── Safety Toggles ────────────────────────────────────────────
READ_ONLY=false        # true → agent never writes to Notion
NO_AUTO_SEND=true      # true → email drafts shown but never sent
SCHEDULE_ENABLED=false # true → enable cron-based daily/weekly jobs

# ── Notion Database IDs (auto-populated by `uniapply setup`) ──
NOTION_UNIVERSITIES_DB=
NOTION_PROGRAMS_DB=
NOTION_ESSAYS_DB=
NOTION_TASKS_DB=
NOTION_INTERESTS_DB=
NOTION_ACTIVITY_LOG_DB=
NOTION_SETTINGS_PAGE_ID=
NOTION_DASHBOARD_PAGE_ID=
